d</span>(), e[i].a = <span class=\"built_in\">read</span>();</span><br><span class=\"line\">            <span class=\"built_in\">add</span>(e[i].u, e[i].v, e[i].l), <span class=\"built_in\">add</span>(e[i].v, e[i].u, e[i].l);</span><br><span class=\"line\">        &#125;</span><br><span class=\"line\">        <span class=\"built_in\">dijkstra</span>();</span><br><span class=\"line\">        <span class=\"keyword\">for</span>(<span class=\"type\">int</span> i = <span class=\"number\">1</span>; i &lt;= n; ++i) tmp[i].l = dis[i];</span><br><span class=\"line\">        <span class=\"keyword\">for</span>(<span class=\"type\">int</span> i = (n + <span class=\"number\">1</span>); i &lt;= (n &lt;&lt; <span class=\"number\">1</span>); ++i) tmp[i].l = INF;</span><br><span class=\"line\">        <span class=\"built_in\">solve</span>(), <span class=\"built_in\">clear</span>();</span><br><span class=\"line\">    &#125;</span><br><span class=\"line\">    <span class=\"keyword\">return</span> <span class=\"number\">0</span>;</span><br><span class=\"line\">&#125;</span><br></pre></td></tr></table></figure></p>\n<h1 id=\"end\"><a class=\"anchor\" href=\"#end\">#</a> End</h1>\n",
